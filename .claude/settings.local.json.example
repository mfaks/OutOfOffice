{
  "permissions": {
    "allow": [
      "Bash(npm run:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/run-checks.sh",
            "timeout": 120,
            "statusMessage": "Running linters and build checks..."
          }
        ]
      }
    ]
  }
}
